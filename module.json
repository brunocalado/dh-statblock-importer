{
  "id": "dh-statblock-importer",
  "title": "Daggerheart: Stats Toolbox",
  "version": "0.3.1",
  "description": "Import using a statblock.",
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "authors": [
    {
      "name": "Mestre Digital",
      "url": "http://youtube.com/@mestredigital",
      "flags": {}
    }
  ],
  "esmodules": [
    "scripts/main.js"
  ],
  "styles": [
    {
      "src": "styles/module.css"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "ru",
      "name": "Русский",
      "path": "lang/ru.json"
    }
  ],
  "media": [
    {
      "type": "setup",
      "url": "modules/dh-statblock-importer/assets/images/thumbnail.webp",
      "thumbnail": "modules/dh-statblock-importer/assets/images/thumbnail.webp",
      "loop": false,
      "flags": {}
    }
  ],
  "relationships": {
    "systems": [
      {
        "id": "daggerheart",
        "type": "system",
        "compatibility": {
          "minimum": "2.3.2"
        }
      }
    ]
  },
  "url": "https://github.com/brunocalado/dh-statblock-importer",
  "manifest": "https://raw.githubusercontent.com/brunocalado/dh-statblock-importer/main/module.json",
  "download": "https://codeload.github.com/brunocalado/dh-statblock-importer/zip/main",
  "packs": [
    {
      "label": "DH_STATBLOCK_IMPORTER.Packs.allFeatures",
      "type": "Item",
      "name": "all-features",
      "path": "packs/all-features",
      "system": "daggerheart",
      "ownership": {
        "PLAYER": "NONE",
        "ASSISTANT": "OWNER"
      },
      "flags": {},
      "banner": "modules/dh-statblock-importer/assets/images/banner.webp"
    },
    {
      "label": "DH_STATBLOCK_IMPORTER.Packs.macros",
      "type": "Macro",
      "name": "macros",
      "path": "packs/macros",
      "system": "daggerheart",
      "ownership": {
        "PLAYER": "NONE",
        "ASSISTANT": "OWNER"
      },
      "flags": {},
      "banner": "modules/dh-statblock-importer/assets/images/banner.webp"
    },
    {
      "label": "DH_STATBLOCK_IMPORTER.Packs.instructions",
      "type": "JournalEntry",
      "name": "journal",
      "path": "packs/journal",
      "system": "daggerheart",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      },
      "flags": {},
      "banner": "modules/dh-statblock-importer/assets/images/banner.webp"
    }
  ],
  "packFolders": [
    {
      "name": "DH_STATBLOCK_IMPORTER.Packs.folder",
      "sorting": "a",
      "color": "#5c0547",
      "packs": [
        "all-features",
        "macros",
        "journal"
      ],
      "folders": []
    }
  ],
  "flags": {}
}
