<div class="standard-form">
    {{!-- Navegação por Abas --}}
    <nav class="dh-config-nav">
        <button type="button" class="dh-config-tab-btn active" data-action="tab" data-target="features">
            <i class="fas fa-star"></i> {{localize "DH_STATBLOCK_IMPORTER.Config.featuresTab"}}
        </button>
        <button type="button" class="dh-config-tab-btn" data-action="tab" data-target="actors">
            <i class="fas fa-users"></i> {{localize "DH_STATBLOCK_IMPORTER.Config.actorsTab"}}
        </button>
        <button type="button" class="dh-config-tab-btn" data-action="tab" data-target="general">
            <i class="fas fa-sliders-h"></i> {{localize "DH_STATBLOCK_IMPORTER.Config.generalTab"}}
        </button>
        <button type="button" class="dh-config-tab-btn" data-action="tab" data-target="icons">
            <i class="fas fa-image"></i> {{localize "DH_STATBLOCK_IMPORTER.Config.iconsTab"}}
        </button>
    </nav>

    {{!-- Aba: Features --}}
    <div class="dh-config-tab-content active" data-tab="features">
        <p class="notes dh-config-notes"><strong>{{localize "DH_STATBLOCK_IMPORTER.Config.itemCompendiums"}}</strong> {{localize "DH_STATBLOCK_IMPORTER.Config.itemCompendiumsHint"}}</p>
        <div class="form-group-stacked dh-config-list">
            {{#each featureCompendiums}}
            <label class="checkbox dh-config-item">
                <input type="checkbox" name="featureCompendiums" value="{{this.id}}" {{checked this.selected}}>
                <span>
                    {{this.title}}
                    <span class="dh-config-item-id">{{this.id}}</span>
                </span>
            </label>
            {{/each}}
        </div>
    </div>

    {{!-- Aba: Actors --}}
    <div class="dh-config-tab-content" data-tab="actors">
        <p class="notes dh-config-notes"><strong>{{localize "DH_STATBLOCK_IMPORTER.Config.actorCompendiums"}}</strong> {{localize "DH_STATBLOCK_IMPORTER.Config.actorCompendiumsHint"}}</p>
        <div class="form-group-stacked dh-config-list">
            {{#each actorCompendiums}}
            <label class="checkbox dh-config-item">
                <input type="checkbox" name="actorCompendiums" value="{{this.id}}" {{checked this.selected}}>
                <span>
                    {{this.title}}
                    <span class="dh-config-item-id">{{this.id}}</span>
                </span>
            </label>
            {{/each}}
        </div>
    </div>

    {{!-- Aba: General --}}
    <div class="dh-config-tab-content" data-tab="general">
        <p class="notes dh-config-notes dh-config-notes--general"><strong>{{localize "DH_STATBLOCK_IMPORTER.Config.generalSettings"}}</strong> {{localize "DH_STATBLOCK_IMPORTER.Config.generalSettingsHint"}}</p>

        <div class="form-group">
            <label for="adversaryFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.adversaryFolderName"}}</label>
            <input type="text" name="adversaryFolderName" value="{{adversaryFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedAdversaries"}}">
        </div>

        <div class="form-group">
            <label for="environmentFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.environmentFolderName"}}</label>
            <input type="text" name="environmentFolderName" value="{{environmentFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedEnvironments"}}">
        </div>

        <div class="form-group">
            <label for="lootFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.lootFolderName"}}</label>
            <input type="text" name="lootFolderName" value="{{lootFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedLoot"}}">
        </div>

        <div class="form-group">
            <label for="consumableFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.consumableFolderName"}}</label>
            <input type="text" name="consumableFolderName" value="{{consumableFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedConsumables"}}">
        </div>

        <div class="form-group">
            <label for="weaponFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.weaponFolderName"}}</label>
            <input type="text" name="weaponFolderName" value="{{weaponFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedWeapons"}}">
        </div>

        <div class="form-group">
            <label for="armorFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.armorFolderName"}}</label>
            <input type="text" name="armorFolderName" value="{{armorFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedArmors"}}">
        </div>

        <div class="form-group">
            <label for="featureFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.featureFolderName"}}</label>
            <input type="text" name="featureFolderName" value="{{featureFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedFeatures"}}">
        </div>

         <div class="form-group">
            <label for="domainCardFolderName">{{localize "DH_STATBLOCK_IMPORTER.Settings.domainCardFolderName"}}</label>
            <input type="text" name="domainCardFolderName" value="{{domainCardFolderName}}" placeholder="{{localize "DH_STATBLOCK_IMPORTER.Folders.importedDomainCards"}}">
        </div>

        <hr class="dh-config-separator">

        <div class="form-group">
            <label for="separatorMode">{{localize "DH_STATBLOCK_IMPORTER.Config.separatorLabel"}}</label>
            <select name="separatorMode">
                <option value="blankLine" {{#if (eq separatorMode "blankLine")}}selected{{/if}}>{{localize "DH_STATBLOCK_IMPORTER.Config.separatorBlankLine"}}</option>
                <option value="separator" {{#if (eq separatorMode "separator")}}selected{{/if}}>{{localize "DH_STATBLOCK_IMPORTER.Config.separatorSeparator"}}</option>
            </select>
            <p class="hint dh-config-hint">{{localize "DH_STATBLOCK_IMPORTER.Config.separatorHint"}}</p>
        </div>
    </div>

    {{!-- Aba: Icons --}}
    <div class="dh-config-tab-content" data-tab="icons">
        <p class="notes dh-config-notes dh-config-notes--general"><strong>{{localize "DH_STATBLOCK_IMPORTER.Config.featureIcons"}}</strong> {{localize "DH_STATBLOCK_IMPORTER.Config.featureIconsHint"}}</p>

        {{!-- Adversary Features --}}
        <p class="hint" style="font-weight:bold; margin-bottom:4px; color: var(--color-text-light-highlight);">{{localize "DH_STATBLOCK_IMPORTER.Config.adversaryFeatures"}}</p>

        <div class="form-group">
            <label>{{localize "DH_STATBLOCK_IMPORTER.Common.featureIcon"}}</label>
            <div class="dh-icon-picker-row">
                <img class="dh-icon-preview" data-target="featureIconAdversary"
                     src="{{featureIconAdversary}}" title="{{localize "DH_STATBLOCK_IMPORTER.Common.currentIcon"}}">
                <input type="text" name="featureIconAdversary" value="{{featureIconAdversary}}">
                <button type="button" class="dh-icon-picker-btn" data-target="featureIconAdversary">
                    <i class="fas fa-file-image"></i>
                </button>
            </div>
        </div>

        <div class="form-group">
            <label class="checkbox" style="font-weight:normal; display:flex; align-items:center; gap:8px;">
                <input type="checkbox" name="featureIconMatchAdversary" {{checked featureIconMatchAdversary}}>
                <span>{{localize "DH_STATBLOCK_IMPORTER.Config.useActorPortrait"}}</span>
            </label>
            <p class="hint dh-config-hint">{{localize "DH_STATBLOCK_IMPORTER.Config.useAdversaryPortraitHint"}}</p>
        </div>

        <hr class="dh-config-separator">

        {{!-- Environment Features --}}
        <p class="hint" style="font-weight:bold; margin-bottom:4px; color: var(--color-text-light-highlight);">{{localize "DH_STATBLOCK_IMPORTER.Config.environmentFeatures"}}</p>

        <div class="form-group">
            <label>{{localize "DH_STATBLOCK_IMPORTER.Common.featureIcon"}}</label>
            <div class="dh-icon-picker-row">
                <img class="dh-icon-preview" data-target="featureIconEnvironment"
                     src="{{featureIconEnvironment}}" title="{{localize "DH_STATBLOCK_IMPORTER.Common.currentIcon"}}">
                <input type="text" name="featureIconEnvironment" value="{{featureIconEnvironment}}">
                <button type="button" class="dh-icon-picker-btn" data-target="featureIconEnvironment">
                    <i class="fas fa-file-image"></i>
                </button>
            </div>
        </div>

        <div class="form-group">
            <label class="checkbox" style="font-weight:normal; display:flex; align-items:center; gap:8px;">
                <input type="checkbox" name="featureIconMatchEnvironment" {{checked featureIconMatchEnvironment}}>
                <span>{{localize "DH_STATBLOCK_IMPORTER.Config.useActorPortrait"}}</span>
            </label>
            <p class="hint dh-config-hint">{{localize "DH_STATBLOCK_IMPORTER.Config.useEnvironmentPortraitHint"}}</p>
        </div>

        <hr class="dh-config-separator">

        {{!-- Standalone Feature Items --}}
        <p class="hint" style="font-weight:bold; margin-bottom:4px; color: var(--color-text-light-highlight);">{{localize "DH_STATBLOCK_IMPORTER.Config.standaloneFeatureItems"}}</p>

        <div class="form-group">
            <label>{{localize "DH_STATBLOCK_IMPORTER.Common.featureIcon"}}</label>
            <div class="dh-icon-picker-row">
                <img class="dh-icon-preview" data-target="featureIconFeature"
                     src="{{featureIconFeature}}" title="{{localize "DH_STATBLOCK_IMPORTER.Common.currentIcon"}}">
                <input type="text" name="featureIconFeature" value="{{featureIconFeature}}">
                <button type="button" class="dh-icon-picker-btn" data-target="featureIconFeature">
                    <i class="fas fa-file-image"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="form-footer">
        <button type="submit" class="save-button">
            <i class="fas fa-save"></i> {{localize "DH_STATBLOCK_IMPORTER.Common.saveSettings"}}
        </button>
    </div>
</div>
