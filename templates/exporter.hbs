<div class="dh-exporter-layout">
    <div class="dh-exporter-wrapper standard-form">

        {{!-- Left Column: Drop Zone --}}
        <div class="dh-column dh-exporter-drop-col">
            <p class="notes dh-notes">{{localize "DH_STATBLOCK_IMPORTER.Exporter.dropPrompt"}}</p>
            <div class="dh-drop-zone" id="dh-exporter-dropzone">
                <div class="dh-drop-placeholder">
                    <i class="fas fa-hand-pointer fa-3x"></i>
                    <p>{{localize "DH_STATBLOCK_IMPORTER.Exporter.dropHere"}}</p>
                    <p class="dh-drop-subtitle">{{localize "DH_STATBLOCK_IMPORTER.Exporter.dropSubtitle"}}</p>
                </div>
                <div class="dh-dropped-actor">
                    <img class="dh-dropped-img" src="">
                    <div class="dh-dropped-info">
                        <div class="dh-dropped-name"></div>
                        <div class="dh-dropped-type"></div>
                    </div>
                    <button type="button" class="dh-clear-btn" data-action="clearActor" title="{{localize "DH_STATBLOCK_IMPORTER.Exporter.removeActor"}}">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>

        {{!-- Right Column: Output --}}
        <div class="dh-column dh-exporter-output-col">
            <p class="notes dh-notes">{{localize "DH_STATBLOCK_IMPORTER.Exporter.generatedStatblock"}}</p>
            <textarea name="statblockOutput" readonly placeholder="{{localize "DH_STATBLOCK_IMPORTER.Exporter.outputPlaceholder"}}"></textarea>
        </div>

    </div>

    {{!-- Footer Actions --}}
    <div class="dh-exporter-actions">
        <button type="button" data-action="copyStatblock" class="save-button">
            <i class="fas fa-copy"></i> {{localize "DH_STATBLOCK_IMPORTER.Common.copyToClipboard"}}
        </button>
    </div>
</div>
