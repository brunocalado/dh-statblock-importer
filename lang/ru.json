      "actor": {
        "tierLine": "^(?:Тир|Tier|Ранг)\\s+(\\d+)\\s*,?\\s*(.+)$",
        "hordeHp": "^(.+?)\\s*\\(\\s*(\\d+)\\s*\\/\\s*(?:HP|ХП|ОЗ|рана|раны|ран)\\s*\\)$"
      },
      "actorTypes": {
